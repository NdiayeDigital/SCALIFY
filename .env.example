# ============================================
# SCALIFY - Configuration des variables d'environnement
# ============================================
# INSTRUCTIONS : Copiez ce fichier en .env et remplissez vos vraies valeurs
# cp .env.example .env
# ============================================

# --- CinetPay Credentials (depuis dashboard.cinetpay.com) ---
CINETPAY_API_KEY=votre_api_key_ici
CINETPAY_SITE_ID=votre_site_id_ici
CINETPAY_SECRET_KEY=votre_secret_key_ici

# --- Configuration Serveur ---
PORT=3000
NODE_ENV=development

# --- URLs de l'application ---
APP_URL=http://localhost:3000
NOTIFY_URL=http://localhost:3000/api/payment/notify
